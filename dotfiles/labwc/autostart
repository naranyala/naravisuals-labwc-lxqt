#!/bin/sh

# LXQt Labwc Session - Autostart
# ================================
# This script runs at labwc startup after the environment is loaded.

# Set wallpaper using swaybg
if command -v swaybg &>/dev/null; then
  WALLPAPER_DIR="$HOME/.local/share/wallpapers"
  if [ -f "$HOME/.config/labwc/wallpaper" ]; then
    WALLPAPER=$(cat "$HOME/.config/labwc/wallpaper")
  elif [ -f "$WALLPAPER_DIR/origami-dark-labwc.png" ]; then
    WALLPAPER="$WALLPAPER_DIR/origami-dark-labwc.png"
  elif [ -f "/usr/share/lxqt/wallpapers/origami-dark-labwc.png" ]; then
    WALLPAPER="/usr/share/lxqt/wallpapers/origami-dark-labwc.png"
  else
    WALLPAPER=""
  fi
  if [ -n "$WALLPAPER" ] && [ -f "$WALLPAPER" ]; then
    swaybg -i "$WALLPAPER" -m fill &
  fi
fi

# Notification daemon
if command -v dunst &>/dev/null; then
  dunst &
elif command -v lxqt-notificationd &>/dev/null; then
  lxqt-notificationd &
fi

# LXQt PolicyKit agent for elevated privileges
if command -v lxqt-policykit-agent &>/dev/null; then
  lxqt-policykit-agent &
fi

# Clipboard manager (Wayland compatible)
if command -v copyq &>/dev/null; then
  copyq --start-server &
elif command -v cliphist &>/dev/null && command -v wl-paste &>/dev/null; then
  wl-paste --watch cliphist store &
fi

# Screen idle / power management
if command -v swayidle &>/dev/null; then
  swayidle -w \
    timeout 300 'if command -v wlopm &>/dev/null; then wlopm --off \*; fi' \
    resume 'if command -v wlopm &>/dev/null; then wlopm --on \*; fi' \
    timeout 600 'swaylock -f' \
    before-sleep 'swaylock -f' &
fi

# Network manager applet
if command -v nm-applet &>/dev/null; then
  nm-applet --indicator &
fi

# Bluetooth tray
if command -v blueman-applet &>/dev/null; then
  blueman-applet &
fi

# GTK portals for Flatpak/file dialogs
if command -v xdg-desktop-portal-lxqt &>/dev/null; then
  /usr/libexec/xdg-desktop-portal-lxqt &
fi
if command -v xdg-desktop-portal &>/dev/null; then
  /usr/libexec/xdg-desktop-portal &
fi

# Update GTK cursor icon (sync with LXQt settings)
if [ -f "$HOME/.config/lxqt/session.conf" ]; then
  GTK_CURSOR=$(grep "^cursor_theme=" "$HOME/.config/lxqt/session.conf" 2>/dev/null | cut -d= -f2)
  GTK_CURSOR_SIZE=$(grep "^cursor_size=" "$HOME/.config/lxqt/session.conf" 2>/dev/null | cut -d= -f2)
  if [ -n "$GTK_CURSOR" ]; then
    gsettings set org.gnome.desktop.interface cursor-theme "$GTK_CURSOR" 2>/dev/null || true
  fi
  if [ -n "$GTK_CURSOR_SIZE" ]; then
    gsettings set org.gnome.desktop.interface cursor-size "$GTK_CURSOR_SIZE" 2>/dev/null || true
  fi
fi

# Auto-mount removable media
if command -v lxqt-pcmanfm-automount &>/dev/null; then
  lxqt-pcmanfm-automount &
fi

# Screenshot tool (Wayland native)
if command -v grimshot &>/dev/null; then
  # Already bound to Print key in rc.xml
  :
fi
