#!/bin/sh
set -e

case "$1" in
    configure)
        # Update desktop database if desktop-file-utils is installed
        if command -v update-desktop-database >/dev/null 2>&1; then
            update-desktop-database 2>/dev/null || true
        fi
        ;;
    abort-upgrade|abort-remove|abort-deconfigure)
        ;;
    *)
        ;;
esac

exit 0
